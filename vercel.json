{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/ondc-site-verification.html",
      "destination": "https://gateway.aadharcha.in/ondc/np/seller/ondc-site-verification.html"
    },
    {
      "source": "/ondc/on_subscribe",
      "destination": "https://gateway.aadharcha.in/ondc/np/seller/on_subscribe"
    },
    {
      "source": "/ondc/:path*",
      "destination": "https://gateway.aadharcha.in/ondc/np/seller/:path*"
    },
    {
      "source": "/api/agent/:path*",
      "destination": "https://gateway.aadharcha.in/api/agent/:path*"
    },
    {
      "source": "/api/agent",
      "destination": "https://gateway.aadharcha.in/api/agent"
    },
    {
      "source": "/api/demo-commerce/:path*",
      "destination": "https://gateway.aadharcha.in/api/demo-commerce/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "installCommand": "npm install"
}
