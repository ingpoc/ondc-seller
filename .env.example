# ============================================================
# Backend API Configuration
# ============================================================
# Explicit production demo mode. Set to true when public deployments should use
# mock catalog and seller-management flows instead of a real commerce backend.
VITE_COMMERCE_DEMO_MODE=false

# Leave empty locally (Vite /api → gateway :43101). Do not use :3001.
# Setting VITE_API_BASE_URL=http://localhost:3001 breaks Incoming Orders (Failed to fetch).
# Orders use GET /api/demo-commerce/seller/orders on the gateway.
# VITE_API_BASE_URL=

# Explicitly disable agent runtime requests in deployments that do not host
# /api/agent/runtime and related control-plane endpoints.
VITE_AGENT_RUNTIME_ENABLED=true

# Optional external agent-control-plane origin for deployed environments.
# Leave empty in local development to use the Vite proxy at /api/agent/* (FlatWatch :43104).
# For deployments, point this to the hosted control plane with CURSOR_API_KEY configured.
VITE_AGENT_CONTROL_PLANE_URL=

# ============================================================
# SSO/Identity Provider Configuration
# ============================================================
# Show Sign in / Booth CTAs driven by GET {VITE_IDENTITY_URL}/api/auth/providers
VITE_IDENTITY_AUTH_ENABLED=true

# Identity gateway (API) — Auth0 start/callback/me live here
# Local: VITE_IDENTITY_URL=http://127.0.0.1:43101
# Web deploy: VITE_IDENTITY_URL=https://gateway.aadharcha.in
VITE_IDENTITY_URL=http://127.0.0.1:43101

# Identity frontend (legacy host UI) — not Auth0 callback host
# Local: VITE_IDENTITY_WEB_URL=http://127.0.0.1:43100
# Production: VITE_IDENTITY_WEB_URL=https://gateway.aadharcha.in
VITE_IDENTITY_WEB_URL=http://127.0.0.1:43100
